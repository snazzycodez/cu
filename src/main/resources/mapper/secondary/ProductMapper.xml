<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.multidb.mapper.secondary.ProductMapper">

    <resultMap id="ProductResultMap" type="com.example.multidb.entity.secondary.Product">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="name" property="name" jdbcType="VARCHAR"/>
        <result column="description" property="description" jdbcType="VARCHAR"/>
        <result column="price" property="price" jdbcType="DECIMAL"/>
        <result column="stock" property="stock" jdbcType="INTEGER"/>
        <result column="category" property="category" jdbcType="VARCHAR"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
        <result column="updated_at" property="updatedAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, name, description, price, stock, category, created_at, updated_at
    </sql>

    <select id="findAll" resultMap="ProductResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM products
        ORDER BY id
    </select>

    <select id="findById" parameterType="long" resultMap="ProductResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM products
        WHERE id = #{id}
    </select>

    <select id="findByCategory" parameterType="string" resultMap="ProductResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM products
        WHERE category = #{category}
        ORDER BY name
    </select>

    <insert id="insert" parameterType="com.example.multidb.entity.secondary.Product" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO products (name, description, price, stock, category, created_at, updated_at)
        VALUES (#{name}, #{description}, #{price}, #{stock}, #{category}, NOW(), NOW())
    </insert>

    <update id="update" parameterType="com.example.multidb.entity.secondary.Product">
        UPDATE products
        SET name = #{name},
            description = #{description},
            price = #{price},
            stock = #{stock},
            category = #{category},
            updated_at = NOW()
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="long">
        DELETE FROM products WHERE id = #{id}
    </delete>

</mapper>